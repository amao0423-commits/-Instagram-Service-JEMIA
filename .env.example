# Resend: https://resend.com/api-keys
RESEND_API_KEY=

# 管理者へ届く通知の宛先
ADMIN_EMAIL=amao0423@hotseller.co.kr

# 送信元（Resend でドメイン認証後は自社ドメインに変更）
# 開発時は onboarding@resend.dev のみ利用可など制限あり — Resend のドキュメントを参照
RESEND_FROM=JEMIA <onboarding@resend.dev>

# Supabase（問い合わせ保存・管理画面用）
# プロジェクト設定 → API から URL / service_role キーを取得（service_role はサーバー専用・漏洩厳禁）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 管理画面（/admin）パスワード保護
ADMIN_DASHBOARD_PASSWORD=
# ランダムな長い文字列（セッション署名用）
ADMIN_SESSION_SECRET=
